{
  "installCommand": "npm install",
  "buildCommand": "npx vite build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://novapromo-backend.vercel.app/api/:path*" },
    { "source": "/uploads/:path*", "destination": "https://novapromo-backend.vercel.app/uploads/:path*" },
    { "source": "/health", "destination": "https://novapromo-backend.vercel.app/health" },
    { "source": "/((?!assets/).*)", "destination": "/index.html" }
  ]
}
