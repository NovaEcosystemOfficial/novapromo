{
  "installCommand": "cd .. && npm install",
  "buildCommand": "cd .. && npm run build -w frontend",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/manifest.webmanifest",
      "headers": [
        { "key": "Content-Type", "value": "application/manifest+json" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://novapromo-backend.vercel.app/api/:path*" },
    { "source": "/uploads/:path*", "destination": "https://novapromo-backend.vercel.app/uploads/:path*" },
    { "source": "/health", "destination": "https://novapromo-backend.vercel.app/health" },
    { "source": "/((?!assets/|sw\\.js|workbox-|manifest\\.webmanifest|icons/|splashes/).*)", "destination": "/index.html" }
  ]
}
