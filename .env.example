# NovaPromo AutoPublisher — Environment Variables
# Segreti → Vercel Dashboard oppure .env.local per sviluppo locale

NODE_ENV=production
APP_URL=https://novapromo.vercel.app
LOG_LEVEL=info
SESSION_SECRET=change-me-to-a-random-32-char-secret-key
ENCRYPTION_KEY=change-me-to-a-random-32-char-secret-key

DB_PATH=./backend/data/novapromo.db
UPLOAD_DIR=./backend/uploads
MAX_FILE_SIZE_MB=50

# Meta / Instagram Login (2025+)
# Facebook App ID (dashboard in alto) — opzionale per altri prodotti Meta
META_APP_ID=
META_APP_SECRET=
# Obbligatori per OAuth Instagram — Dashboard > Instagram > API setup with Instagram login
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
META_REDIRECT_URI=https://novapromo-backend.vercel.app/api/oauth/instagram/callback
META_GRAPH_API_VERSION=v21.0

# Firebase (Brand Intelligence → Firestore brands/{brandId})
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

TIKTOK_ENABLED=false
