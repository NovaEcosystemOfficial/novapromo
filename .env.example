# NovaPromo AutoPublisher — Environment Variables
# Segreti → Vercel Dashboard oppure .env.local per sviluppo locale

NODE_ENV=production
APP_URL=https://novapromo.vercel.app
LOG_LEVEL=info
SESSION_SECRET=change-me-to-a-random-32-char-secret-key
ENCRYPTION_KEY=change-me-to-a-random-32-char-secret-key

DB_PATH=./backend/data/novapromo.db
UPLOAD_DIR=./backend/uploads
MAX_FILE_SIZE_MB=50

# Meta (Instagram Login — scope 2025+)
META_APP_ID=
META_APP_SECRET=
# Opzionale se diverso da META_APP_ID (Dashboard > Instagram > Business login)
# INSTAGRAM_APP_ID=
# INSTAGRAM_APP_SECRET=
META_REDIRECT_URI=https://novapromo.vercel.app/api/oauth/instagram/callback
META_GRAPH_API_VERSION=v21.0

TIKTOK_ENABLED=false
