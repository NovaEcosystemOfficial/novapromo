# =============================================================================
# NovaPromo — variabili condivise (copia in .env e .env.local, NON committare)
# Progetto Firebase: NovaEcosystem | Web App: NovaPromo
# =============================================================================

# --- Backend: Firebase Admin (Project settings → Service accounts → Generate key) ---
FIREBASE_PROJECT_ID=novaecosystem-b8a4b
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@novaecosystem-b8a4b.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=novaecosystem-b8a4b.firebasestorage.app

# firestore in produzione | sqlite in dev locale
DATA_STORE=firebase

# --- Frontend (Vite): Firebase Web App "NovaPromo" → SDK setup ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=novaecosystem-b8a4b.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=novaecosystem-b8a4b
VITE_FIREBASE_STORAGE_BUCKET=novaecosystem-b8a4b.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- App URLs ---
FRONTEND_URL=https://novapromo.vercel.app
BACKEND_URL=https://novapromo-backend.vercel.app
META_REDIRECT_URI=https://novapromo-backend.vercel.app/api/oauth/instagram/callback

# --- Sicurezza ---
ENCRYPTION_KEY=change-me-min-32-characters-long!!
SESSION_SECRET=change-me-session-secret

# --- OpenAI (AI Studio — solo backend) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Instagram OAuth (invariato) ---
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
