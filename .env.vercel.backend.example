# Template — rigenera con: npm run generate:vercel-env
# Import in Vercel → novapromo-backend → Environment Variables → Import .env

NODE_ENV=production
APP_URL=https://novapromo.vercel.app
FRONTEND_URL=https://novapromo.vercel.app
