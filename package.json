{
  "name": "novapromo-autopublisher",
  "version": "1.0.0",
  "private": true,
  "description": "NovaPromo AutoPublisher — web app autonoma (Instagram)",
  "author": "NovaPromo",
  "type": "module",
  "main": "electron/main.js",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "predev": "node scripts/free-port.js 3001 && node scripts/free-port.js 5173",
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run dev -w backend\" \"npm run dev -w frontend\"",
    "dev:web": "npm run dev",
    "dev:backend": "npm run dev -w backend",
    "dev:frontend": "npm run dev -w frontend",
    "dev:electron": "cross-env NOVAPROMO_USE_CLOUD=1 electron .",
    "dev:electron:local": "electron .",
    "build": "npm run build -w frontend",
    "build:desktop": "cross-env ELECTRON_BUILD=1 VITE_RUNTIME=desktop VITE_TIKTOK_ENABLED=false VITE_DESKTOP_API_URL=http://localhost:3001 npm run build -w frontend",
    "dist": "electron-builder --win",
    "dist:dir": "electron-builder --win dir",
    "dist:nsis": "electron-builder --win nsis",
    "dist:appx": "electron-builder --win appx",
    "dist:msix": "electron-builder --win appx",
    "install:all": "npm install",
    "test:firebase": "node scripts/test-firebase-integration.mjs",
    "test:facebook": "node scripts/test-facebook-publishing.mjs",
    "test:premium-ai": "node scripts/test-premium-ai.mjs",
    "test:creative-studio": "node scripts/test-creative-studio.mjs",
    "test:accounts-plans": "node scripts/test-accounts-plans.mjs",
    "test:stripe-subscriptions": "node scripts/test-stripe-subscriptions.mjs",
    "test:scheduler": "node scripts/test-scheduler.mjs",
    "test:publish-status": "node scripts/test-publish-status.mjs",
    "test:ai-firestore": "node scripts/test-ai-firestore-sanitize.mjs",
    "setup:firebase": "node scripts/setup-firebase-env.mjs",
    "bootstrap:firebase": "node scripts/bootstrap-firebase-project.mjs",
    "deploy:firebase-rules": "node scripts/deploy-firebase-rules-admin.mjs",
    "deploy:firebase-rules:api": "node scripts/deploy-firebase-rules.mjs",
    "check:firebase-rules": "node scripts/check-firebase-rules.mjs",
    "generate:vercel-env": "node scripts/generate-vercel-env.mjs",
    "validate:vercel-env": "node scripts/validate-vercel-env.mjs"
  },
  "dependencies": {
    "express": "^4.21.2"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.novapromo.autopublisher",
    "productName": "NovaPromo AutoPublisher",
    "copyright": "Copyright © NovaPromo",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "package.json",
      "build/icon.png"
    ],
    "asar": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "appx",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.png",
      "artifactName": "NovaPromo-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NovaPromo AutoPublisher"
    },
    "appx": {
      "identityName": "NovaPromo.AutoPublisher",
      "applicationId": "NovaPromoAutoPublisher",
      "publisher": "CN=NovaPromo",
      "publisherDisplayName": "NovaPromo",
      "displayName": "NovaPromo AutoPublisher",
      "languages": ["it-IT", "en-US"],
      "backgroundColor": "#050506"
    },
    "protocols": [
      {
        "name": "NovaPromo OAuth",
        "schemes": ["novapromo"]
      }
    ]
  }
}
